{
    "Logging": {
        "LogLevel": {
            "Default": "Warning",
            "Microsoft.AspNetCore": "Warning",
            "AnswerCode.Services.LLMRequestLoggingHandler": "Warning"
        }
    },
    "AllowedHosts": "*",
    "AllowedOrigins": [],
    "Authentication": {
        "Google": {
            "ClientId": "your-client-id",
            "ClientSecret": "your-client-secret"
        }
    },
    "UserStorage": {
        "MaxSizeMB": 300
    },
    "UploadCleanup": {
        "ScanIntervalMinutes": 10,
        "MaxAgeMinutes": 120
    },
    "LspServers": {
        "RequestTimeoutSeconds": 30,
        "IdleTimeoutSeconds": 300,
        "Servers": {
            "TypeScript": {
                "Command": "node",
                "Arguments": [
                    "./lsp-servers/node_modules/typescript-language-server/lib/cli.mjs",
                    "--stdio"
                ],
                "LanguageIds": [ "typescript", "typescriptreact", "javascript", "javascriptreact" ]
            },
            "Python": {
                "Command": "node",
                "Arguments": [
                    "./lsp-servers/node_modules/pyright/langserver.index.js",
                    "--stdio"
                ],
                "LanguageIds": [ "python" ]
            },
            "Go": {
                "Command": "./lsp-servers/bin/gopls.exe",
                "Arguments": [],
                "LanguageIds": [ "go" ]
            },
            "Rust": {
                "Command": "./lsp-servers/bin/rust-analyzer.exe",
                "Arguments": [],
                "LanguageIds": [ "rust" ]
            }
        }
    },
    "Tavily": {
        "ApiKey": ""
    },
    "LLM": {
        "DefaultProvider": "gpt-5.2",
        "Providers": {
            "gpt-oss-120b": {
                "Endpoint": "https://bruce-mi8e3t1w-eastus2.services.ai.azure.com/openai/v1/",
                "ApiKey": "",
                "Model": "gpt-oss-120b",
                "DisplayName": "gpt-oss-120b"
            },
            "gpt-5.2": {
                "Endpoint": "https://bruce-mi8e3t1w-eastus2.cognitiveservices.azure.com/",
                "ApiKey": "",
                "Model": "gpt-5.2",
                "DisplayName": "gpt-5.2"
            },
            "gpt-5-chat": {
                "Endpoint": "https://bruce-mi8e3t1w-eastus2.cognitiveservices.azure.com/",
                "ApiKey": "",
                "DeploymentName": "gpt-5-chat",
                "DisplayName": "gpt-5-chat"
            },
            "gemma-4-31b-it": {
                "Endpoint": "https://generativelanguage.googleapis.com/v1beta/openai/",
                "ApiKey": "",
                "Model": "gemma-4-31b-it",
                "DisplayName": "gemma-4-31b-it"
            },
            "gpt-5.4": {
                "Endpoint": "https://bruce-mi8e3t1w-eastus2.cognitiveservices.azure.com/",
                "ApiKey": "",
                "DeploymentName": "gpt-5.4",
                "Model": "gpt-5.4",
                "DisplayName": "gpt-5.4",
                "UseReasoningModelParameters": true
            }
        }
    }
}