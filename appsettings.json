{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "AnswerCode.Services.LLMRequestLoggingHandler": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AllowedOrigins": [],
  "Authentication": {
    "Google": {
      "ClientId": "your-client-id",
      "ClientSecret": "your-client-secret"
    }
  },
  "UserStorage": {
    "MaxSizeMB": 300
  },
  "UploadCleanup": {
    "ScanIntervalMinutes": 10,
    "MaxAgeMinutes": 120
  },
  "LLM": {
    "DefaultProvider": "OpenAI",
    "Providers": {
      "OpenAI": {
        "Endpoint": "url",
        "ApiKey": "api key",
        "Model": "gpt-oss-120b",
        "DisplayName": "gpt-oss-120b"
      },
      "AzureOpenAI": {
        "Endpoint": "url",
        "ApiKey": "api key",
        "Model": "gpt-5-chat",
        "DisplayName": "Azure-GPT-5-Chat"
      }
    }
  }
}